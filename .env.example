# MatuMailer Platform Environment

# API Server
PORT=4001
JWT_SECRET=your-super-secret-jwt-key-min-32-characters
ENCRYPTION_KEY=your-32-char-encryption-key-for-smtp
CORS_ORIGIN=http://localhost:3000

# MatuDB (@devjuanes/matuclient) — replaces Prisma
MATUDB_URL=http://localhost:3001
MATUDB_PROJECT_ID=matumailer
MATUDB_API_KEY=your_matudb_service_key

# Dashboard
NEXT_PUBLIC_API_URL=http://localhost:4001

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Cola de envíos programados (intervalo del worker en ms)
SCHEDULER_INTERVAL_MS=30000
