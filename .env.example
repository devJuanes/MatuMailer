# MatuMailer Platform Environment

# API Server
PORT=4001
JWT_SECRET=your-super-secret-jwt-key-min-32-characters
ENCRYPTION_KEY=your-32-char-encryption-key-for-smtp
CORS_ORIGIN=http://localhost:3000

# MatuDB (@devjuanes/matuclient)
MATUDB_URL=http://localhost:3001
MATUDB_PROJECT_ID=matumailer
MATUDB_API_KEY=your_matudb_service_key

# Dashboard (copiar también a apps/dashboard/.env.local para Next.js en dev)
NEXT_PUBLIC_API_URL=http://localhost:4001
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CONTACT_EMAIL=contacto@matubyte.com
NEXT_PUBLIC_CONTACT_PHONE=+57 333 277 1764
NEXT_PUBLIC_CONTACT_WHATSAPP=573332771764
NEXT_PUBLIC_CONTACT_WHATSAPP_MSG=Hola, me interesa conocer más sobre MatuMailer.

# URL pública del dashboard (API / PayMatuByte callbacks)
APP_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Cola de envíos programados (intervalo del worker en ms)
SCHEDULER_INTERVAL_MS=30000

# PayMatuByte (Premium)
PAYMATUBYTE_URL=https://pay.matubyte.com
PAYMATUBYTE_API_KEY=pk_matumailer_prod_cambiar

# Producción (ejemplo)
# NEXT_PUBLIC_API_URL=https://api.matucatalogo.com
# NEXT_PUBLIC_APP_URL=https://mail.matucatalogo.com
# APP_URL=https://mail.matucatalogo.com
# CORS_ORIGIN=https://mail.matucatalogo.com
