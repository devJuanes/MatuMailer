PORT=4000
NODE_ENV=development

# MatuDB (replaces Prisma)
MATUDB_URL=http://localhost:3001
MATUDB_PROJECT_ID=matumailer
MATUDB_API_KEY=your_matudb_service_key

JWT_SECRET=change-me-to-a-secure-random-string-min-32-chars
ENCRYPTION_KEY=change-me-32-byte-hex-key-for-smtp-encryption

CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
