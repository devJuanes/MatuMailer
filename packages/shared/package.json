{
  "name": "@matumailer/shared",
  "version": "1.0.0",
  "private": true,
  "description": "Shared types and schemas for MatuMailer (monorepo only; el SDK publica todo empaquetado)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/devJuanes/MatuMailer.git",
    "directory": "packages/shared"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
