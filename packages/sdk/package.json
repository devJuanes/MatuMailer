{
  "name": "matumailer",
  "version": "1.0.0",
  "description": "Official MatuMailer SDK — send emails with templates via API",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsup",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "keywords": [
    "email",
    "smtp",
    "matumailer",
    "transactional-email"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/devJuanes/MatuMailer.git",
    "directory": "packages/sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@matumailer/shared": "*",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  }
}
